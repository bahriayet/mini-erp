# SQLite Database URL
# Secara default, Prisma SQLite menggunakan lokasi file relatif.
# Contoh: "file:./dev.db" atau "file:./prisma/dev.db"
DATABASE_URL="file:./dev.db"

# NextAuth / Auth.js Configuration
# Hasilkan kunci aman 32-karakter untuk produksi menggunakan: openssl rand -base64 32
AUTH_SECRET="super-secret-random-32-character-key-for-erp-portfolio-dev"
NEXTAUTH_URL="http://localhost:3000"
